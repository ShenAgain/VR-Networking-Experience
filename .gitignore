# ======================================
# Unity + Meta Quest VR + Visual Studio
# Keep APK builds for FYP submission
# Place at project root
# ======================================

# -----------------
# Unity Generated
# -----------------
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/
/BuildCache/

# -----------------
# Build Folders
# Ignore everything except APK
# -----------------
/[Bb]uild/
/[Bb]uilds/*
!/Builds/*.apk
!/Builds/**/*.apk

# Optional: keep AAB too
# !/Builds/*.aab
# !/Builds/**/*.aab

# Ignore release binaries elsewhere
*.aab
*.app
*.unitypackage
*.unity3d

# -----------------
# IDE / Editor Files
# -----------------
.vs/
.idea/
.vscode/
.gradle/
.consulo/
ExportedObj/

# Visual Studio / Rider generated
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.sln.iml

# Unity generated meta debug files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# -----------------
# Crash / Logs
# -----------------
sysinfo.txt
crashlytics-build.properties

# -----------------
# Addressables
# -----------------
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# -----------------
# Unity Plugins
# -----------------
/[Aa]ssets/Plugins/Editor/JetBrains*

# -----------------
# Substance Painter
# -----------------
*.spp
*.sbsar

# -----------------
# macOS
# -----------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# -----------------
# Windows
# -----------------
Thumbs.db
ehthumbs.db
[Dd]esktop.ini
$RECYCLE.BIN/
*.stackdump
*.utmp
# -----------------
# Temporary Editor Files
# -----------------
*.swp
*.swo
*~

